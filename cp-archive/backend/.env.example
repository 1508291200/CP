# 环境变量示例 - 复制为 .env 并填写实际值
# cp .env.example .env

# ── 基础配置 ────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── 数据库 ──────────────────────────────────────────
# 格式: postgresql://user:password@host:port/database
# Zeabur 会自动注入此变量，本地开发需手动填写
DATABASE_URL=postgresql://cpuser:yourpassword@localhost:5432/cparchive

# ── Redis ───────────────────────────────────────────
# Zeabur 会自动注入此变量
REDIS_URL=redis://localhost:6379

# ── JWT 密钥（生产环境必须设置，至少64位随机字符）────
# 生成命令: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=dev-secret-change-in-production
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production

# ── 站点公开 URL（用于生成文件链接）─────────────────
# 本地开发
PUBLIC_URL=http://localhost:3000
# Zeabur 部署后填写你的域名
# PUBLIC_URL=https://api.yourdomain.com

# ── CORS 允许的前端域名（生产环境，逗号分隔）────────
# 本地开发留空即可（会自动允许所有）
ALLOWED_ORIGINS=
# 示例: ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── 文件上传（本地模式）────────────────────────────
UPLOAD_DIR=./uploads

# ── 存储驱动: local（本地磁盘）或 r2（Cloudflare R2）
STORAGE_DRIVER=local

# ── Cloudflare R2（仅 STORAGE_DRIVER=r2 时需要填写）
# 在 https://dash.cloudflare.com/ 创建 R2 存储桶后获取
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cp-archive
# R2 公开访问域名（在 R2 存储桶设置里启用"公开访问"后获得）
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
