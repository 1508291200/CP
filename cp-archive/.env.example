# 生产环境变量 - 复制为 .env 并填写实际值
# cp .env.example .env

# ── 数据库密码 ──────────────────────────────────────────
# 使用强密码（建议 32 位以上随机字符）
DB_PASSWORD=your_strong_database_password_here

# ── JWT 密钥（生产环境必填，至少 64 位随机字符）────────
# 生成命令: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_jwt_secret_here
JWT_REFRESH_SECRET=your_64_char_refresh_secret_here

# ── 域名（用于 Nginx 配置和 SSL 证书）─────────────────
DOMAIN=yourdomain.com

# ── CORS 允许来源（逗号分隔，模式B跨域部署时必填）────
# 示例：ALLOWED_ORIGINS=https://your-app.pages.dev,https://your-domain.com
ALLOWED_ORIGINS=

# ── Cookie SameSite 策略 ─────────────────────────────
# 同域部署（模式C VPS）: Strict
# 跨域部署（模式B 前端Cloudflare+后端PaaS）: None
COOKIE_SAMESITE=Strict

# ── Cloudflare R2 对象存储（可选，替代本地磁盘存储）──
# 启用后文件上传/读取走 R2，不再依赖本地磁盘
R2_ENABLED=false
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=cp-archive-media
# R2 桶绑定的自定义公共域名（用于生成图片访问 URL），无尾斜线
# 示例：R2_PUBLIC_URL=https://media.yourdomain.com
R2_PUBLIC_URL=https://media.yourdomain.com

